# ===========================================
# NEA Intranet Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# ---------- Database ----------
DATABASE_URL=postgresql://nea_user:nea_password@localhost:5432/nea_intranet
# For Docker: postgresql://nea_user:nea_password@postgres:5432/nea_intranet

# ---------- JWT Authentication ----------
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Redis (optional caching) ----------
REDIS_URL=redis://localhost:6379/0
# For Docker: redis://redis:6379/0

# ---------- AI / Embeddings ----------
# Using local sentence-transformers (no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./vector_store

# ---------- File Storage ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ---------- App Settings ----------
APP_NAME=NEA Intranet Portal
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Super Admin (Seeded on first run) ----------
SUPER_ADMIN_EMAIL=admin@nea.org.np
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Administrator
